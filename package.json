{
  "name": "empo-app-ci-tools",
  "private": true,
  "description": "Pinned versions of Node-based CI lint/format tools. Not shipped with the app; consumed only by .github/workflows/.",
  "scripts": {
    "prepare": "lefthook install --reset-hooks-path",
    "fmt:check": "oxfmt --check altstore-source.json ios/Empo/project.yml ios/Empo/curated-patches/gameRegistry.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lefthook": "2.1.9",
    "markdownlint-cli": "0.48.0",
    "oxfmt": "0.55.0"
  }
}
