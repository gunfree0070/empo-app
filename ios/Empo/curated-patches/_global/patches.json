// Global Empo patches - applied to EVERY imported game regardless of
// canonical id. Reserve this for fixes that are toolkit-wide or
// engine-wide (Pokemon Essentials common idioms, RGSS quirks, etc.).
//
// Format: JoiPlay-compatible. See `_global/README.md` for schema notes
// once we add one. Top-level "rpgm" array of {key, value} objects.
// Keys prefixed with "[regex]" use std::regex_replace ECMAScript syntax.
//
{
  "rpgm": [
    {
      "key": "[regex]def pbGetTimeNow\\b[\\s\\S]*?\\nend\\b",
      "value": "def pbGetTimeNow\n  return Time.now\nend"
    },
    {
      "key": "[regex]Graphics\\.frame_rate\\s*=\\s*\\d+",
      "value": "Graphics.frame_rate = 40"
    }
  ]
}
